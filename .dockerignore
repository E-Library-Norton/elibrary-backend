# ─── Build & runtime artifacts ────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Version control ─────────────────────────────────────────────────────────
.git
.gitignore

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
.vscode
.idea
*.swp

# ─── Logs & runtime data (not part of image) ─────────────────────────────────
logs/
uploads/
backups/
books/

# ─── Shell scripts (only entrypoint is needed inside the image) ──────────────
*.sh
!docker-entrypoint.sh

# ─── Docker itself ────────────────────────────────────────────────────────────
Dockerfile
docker-compose*.yml
.dockerignore

# ─── Postman / docs ──────────────────────────────────────────────────────────
*.postman_collection.json
README.md
BACKLOG.md
DIAGRAM.md
PLAN.md
PRD.md
TASKS.md
