# # Server
PORT=5005

# Database Configuration (production — Render managed PostgreSQL)
DATABASE_URL=postgresql://your_db_user:your_db_password@your-host.render.com/your_db_name


ACCESS_TOKEN_SECRET=change-me-strong-random-secret
REFRESH_TOKEN_SECRET=change-me-another-strong-secret
FORGOT_PASSWORD_SECRET=change-me-at-least-32-random-characters
ACCESS_TOKEN_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_IN=60d

# Google API KEY → https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-gemini-api-key

# CLOUDFLARE R2 CONFIG → https://dash.cloudflare.com/r2
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=elibrary-files
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Optional: set to your R2 public bucket URL (e.g. https://pub-xxx.r2.dev)
# Leave empty to use path-style endpoint URLs
R2_PUBLIC_URL=

# ── Email (for OTP forgot-password emails) ────────────────────────────────────
# Gmail: turn on 2FA → go to myaccount.google.com/apppasswords → generate App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Vector Search / Scan-to-Search
VECTOR_SEARCH_SERVICE_URL=http://localhost:8001

# ── OAuth Social Login ────────────────────────────────────────────────────────
# URL of this backend (used to build OAuth callback URLs)
BACKEND_URL=http://localhost:5005
# URL of the student frontend (OAuth redirects here after success)
FRONTEND_URL=http://localhost:3000

# Google OAuth  → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth → https://developers.facebook.com/apps
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# GitHub OAuth   → https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
